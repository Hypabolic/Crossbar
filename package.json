{
  "name": "@hypabolic/crossbar",
  "version": "0.5.1",
  "description": "Connect the Pi coding agent to local & self-hosted LLMs — Ollama, LM Studio, llama.cpp, llama-swap, vLLM, and any OpenAI-compatible server. Auto-discovery, model switching, and zero-JSON in-TUI onboarding.",
  "type": "module",
  "license": "MIT",
  "author": "Hypabolic",
  "homepage": "https://github.com/Hypabolic/Crossbar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hypabolic/Crossbar.git"
  },
  "bugs": {
    "url": "https://github.com/Hypabolic/Crossbar/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "llm",
    "local-llm",
    "ollama",
    "lm-studio",
    "llama.cpp",
    "llama-swap",
    "vllm",
    "openai-compatible"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/Hypabolic/Crossbar/main/docs/onboarding.gif"
  },
  "files": [
    "src",
    "docs/onboarding.gif",
    "RESEARCH.md",
    "CAPABILITY-MATRIX.md",
    "ARCHITECTURE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:lmstudio": "node scripts/fake-lmstudio.mjs",
    "demo:gif": "node scripts/gen-onboarding-gif.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.9",
    "@earendil-works/pi-tui": "0.79.9",
    "typebox": "1.2.19"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.9",
    "@earendil-works/pi-tui": "0.79.9",
    "@types/node": "26.0.0",
    "typebox": "1.2.19",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
